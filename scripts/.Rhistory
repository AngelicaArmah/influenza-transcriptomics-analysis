# ---------------------------------
# 0. GLOBAL SETTINGS
# ---------------------------------
# Increase download timeout for large GEO files
options(timeout = 3600)
# Set seed for reproducibility of analysis
set.seed(123)
# ----------------------------------
# 1. PACKAGES
# ----------------------------------
# Project root handling and reproducible file paths (here; MĂĽller, 2025)
library(here)
# GEO database source (Edgar et al., 2002)
# GEOquery R package for accessing GEO datasets (Davis & Meltzer, 2007)
library(GEOquery)
# RNA-seq differential expression (Love et al., 2014)
library(DESeq2)
# Load apeglm package for log2 fold change shrinkage (Zhu et al., 2018)
library(apeglm)
# Data visualization using Grammar of Graphics (ggplot2; Wickham, 2016)
library(ggplot2)
# Prevent overlapping labels in ggplot2 visualizations (ggrepel; Slowikowski et al., 2026)
library(ggrepel)
# Data manipulation using tidy data grammar (dplyr; Wickham et al., 2026)
library(dplyr)
# Heatmap visualization (pheatmap; Kolde, 2025)
library(pheatmap)
# Human gene annotation database (org.Hs.eg.db; Carlson, 2025)
library(org.Hs.eg.db)
# ----------------------------------------------------
# 2. PROJECT PATH SETUP (reproducible structure)
# -----------------------------------------------------
# Define reproducible project root using here (MĂĽller, 2025)
project_root <- here::here()
# Safety check to ensure project root is correctly detected before proceeding
if (!dir.exists(project_root)) stop("Project root not found")
# Define reproducible data directory within project structure
base_dir <- file.path(project_root, "data")
# Dataset-specific directory for isolated GEO storage (improves reproducibility)
geo_dir <- file.path(base_dir, "GSE252713")
# ----------------------------------------
# 3. CREATE FOLDERS SAFELY
# ----------------------------------------
# Ensure reproducible data directory exists before downloading GEO files
if (!dir.exists(base_dir)) {
dir.create(base_dir, recursive = TRUE)
}
dir.create(geo_dir, recursive = TRUE)
#--------------------------
# 3. GEO DATA DOWNLOAD
#--------------------------
# List existing files
files <- list.files(geo_dir, recursive = TRUE, full.names = TRUE)
# Identify likely data files (biologically meaningful filter)
data_files <- files[grepl("count|counts|readcount|matrix", files, ignore.case = TRUE)]
getGEOSuppFiles("GSE252713", baseDir = geo_dir)
# Refresh after download
files <- list.files(geo_dir, recursive = TRUE, full.names = TRUE)
data_files <- files[grepl("count|counts|readcount|matrix",
files,
ignore.case = TRUE)]
# Download only if no relevant data files are found
if (length(data_files) == 0) {
message("Downloading GEO supplementary files...")
getGEOSuppFiles("GSE252713", baseDir = geo_dir)
}
# Refresh after download
files <- list.files(geo_dir, recursive = TRUE, full.names = TRUE)
data_files <- files[grepl("count|counts|readcount|matrix",
files,
ignore.case = TRUE)]
# Show detected files
print(data_files)
# Select gene-level count file (robust pattern)
count_file <- data_files[grepl("genes.*readcount", data_files)]
# Print selected file
print(count_file)
# Strict validation checks (clear error messages)
if (length(count_file) == 0) stop("No gene count file found")
if (length(count_file) > 1) stop("Multiple gene count files found")
# Inspect file
head(read.table(gzfile(count_file), sep = "\t", header = TRUE))
# ------------------------------
# 1. RAW COUNT IMPORT
#-------------------------------
# Rows = genes/transcripts, columns = samples
raw_counts <- read.table(
gzfile(count_file),
sep = "\t",
header = TRUE,
row.names = 1,
check.names = FALSE,
stringsAsFactors = FALSE
)
# Convert to numeric matrix (required for downstream analysis)
raw_counts <- as.matrix(raw_counts)
# -----------------------------
# 2. INITIAL QUALITY CONTROL
# -----------------------------
# Check dataset dimensions (genes Ă— samples)
dim(raw_counts)
# Inspect first few rows of expression matrix
head(raw_counts[, 1:5])
# ------------------------------
# 3. GENE IDENTIFIER EXTRACTION
# ------------------------------
# Extract gene identifiers from expression matrix
gene_ids <- rownames(raw_counts)
head(gene_ids)
# ------------------------------
# 4. ENSG GENE FILTERING
# ------------------------------
# Identify Ensembl gene IDs (ENSG)
ensg_keep <- grepl("^ENSG", gene_ids)
# Subset matrix to retain only ENSG genes
raw_counts_ensg <- raw_counts[ensg_keep, ]
# ------------------------------
# 5. FILTER VALIDATION
# ------------------------------
# Check dimensions before and after filtering
dim(raw_counts)
dim(raw_counts_ensg)
# Validate filtering by confirming no non-ENSG IDs remain
non_ensg_count <- sum(!grepl("^ENSG", rownames(raw_counts_ensg)))
non_ensg_count
# Inspect filtered gene IDs
head(rownames(raw_counts_ensg))
# Enforce strict validation to ensure only ENSG genes remain
stopifnot(all(grepl("^ENSG", rownames(raw_counts_ensg))))
# ---------------------------
# 6. FINAL STRUCTURE CHECK
# --------------------------
# Inspect column names
colnames(raw_counts_ensg)
# ------------------------------------------------
# 1. EXTRACT SAMPLE IDENTIFIERS
# ------------------------------------------------
samples <- colnames(raw_counts_ensg)
# -------------------------------------------------
# 2. INITIALIZE METADATA TABLE
# -------------------------------------------------
metadata <- data.frame(sample = samples)
# Optional but recommended: set rownames for clarity
rownames(metadata) <- metadata$sample
# -------------------------------------------------------
# 3. DEFINE EXPERIMENTAL CONDITIONS AND REPLICATES
# -------------------------------------------------------
# Assign biological groups (control vs infection)
metadata$condition <- ifelse(grepl("^mock", metadata$sample, ignore.case = TRUE),
"control",
"infection")
# Extract replicate numbers from sample names
metadata$replicate <- sub(".*_(\\d+)$", "\\1", metadata$sample)
# -------------------------------------------------
# 4. INSPECT METADATA STRUCTURE
# -------------------------------------------------
head(metadata)
# ----------------------------------------------------
# 5. VALIDATE SAMPLE CONSISTENCY
# ---------------------------------------------------
# Ensure metadata samples match expression matrix columns
stopifnot(setequal(metadata$sample, colnames(raw_counts_ensg)))
# --------------------------------------------
# 6. ALIGN METADATA WITH EXPRESSION MATRIX
# --------------------------------------------
metadata <- metadata[colnames(raw_counts_ensg), , drop = FALSE]
# --------------------------------------------------
# 7. FORMAT VARIABLES FOR STATISTICAL MODELING
# --------------------------------------------------
# Convert condition to factor with correct reference level (control)
metadata$condition <- factor(metadata$condition,
levels = c("control", "infection"))
# Convert replicate to factor (good practice for modeling consistency)
metadata$replicate <- factor(metadata$replicate)
# =========================================================
# 1. CHECK FOR DUPLICATE GENE IDS
# =========================================================
sum(duplicated(rownames(raw_counts_ensg)))
# =========================================================
# 2. VERIFY COUNTS ARE INTEGERS
# =========================================================
all(raw_counts_ensg == round(raw_counts_ensg))
# =========================================================
# 3. REMOVE LOWLY EXPRESSED GENES (OPTIONAL)
# =========================================================
keep <- rowSums(raw_counts_ensg) >= 10
raw_counts_ensg <- raw_counts_ensg[keep, ]
# Check new dimensions after filtering
dim(raw_counts_ensg)
# Create DESeq2 object from counts and metadata (Love et al., 2014)
dds <- DESeqDataSetFromMatrix(
countData = raw_counts_ensg,
colData = metadata,
design = ~ condition
)
# Run full DESeq2 pipeline (normalization, dispersion, model fitting)
dds <- DESeq(dds)
# Extract differential expression results with defined contrast
res <- results(dds, contrast = c("condition", "infection", "control"))
# Summarize differential expression results
summary(res)
# View top differentially expressed genes sorted by significance
head(res[order(res$padj, na.last = NA), ])
# Plot p-value distribution for QC
hist(res$pvalue, breaks = 50, main = "P-value distribution", xlab = "p-value")
# Count significantly differentially expressed genes (FDR < 0.05)
sum(res$padj < 0.05 & !is.na(res$padj))
# Perform log2 fold change shrinkage for visualization [DESeq2 package]
resLFC <- lfcShrink(
dds,
coef = "condition_infection_vs_control",
type = "apeglm"
)
# Compare original vs shrunk fold changes
head(res$log2FoldChange)
head(resLFC$log2FoldChange)
# Create ranked gene list for pathway analysis
ranked_genes <- res_clean$log2FoldChange
# Create ranked gene list for pathway analysis
ranked_genes <- res_clean$log2FoldChange
# Create ranked gene list for pathway analysis
res_clean <- res[!is.na(res$padj), ]
ranked_genes <- res_clean$log2FoldChange
names(ranked_genes) <- rownames(res_clean)
ranked_genes <- sort(ranked_genes, decreasing = TRUE)
# Transform count data using variance stabilizing transformation for PCA visualization (Love et al., 2014)
vsd <- vst(dds, blind = FALSE)
# Perform PCA to assess sample clustering by experimental condition
plotPCA(vsd, intgroup = "condition")
# Compute pairwise Euclidean distances between samples using VST-transformed expression values for global similarity assessment
sampleDists <- dist(t(assay(vsd)))
# Visualize sample-to-sample distances as a heatmap to assess clustering and detect potential outliers
pheatmap(as.matrix(sampleDists),
main = "Sample Distance Heatmap")
# Compute total library sizes per sample to evaluate sequencing depth consistency across conditions
colSums(counts(dds))
# --------------------------------------------------
# 1. CLEAN RESULTS
# --------------------------------------------------
# Add Ensembl IDs
res_clean$ensembl <- rownames(res_clean)
# --------------------------------------------------
# 2. MAP GENE NAMES (safer merge)
# --------------------------------------------------
BiocManager::install("biomaRt")
library(biomaRt)
# Heatmap visualization (pheatmap; Kolde, 2025)
library(pheatmap)
# Human gene annotation database (org.Hs.eg.db; Carlson, 2025)
library(org.Hs.eg.db)
citation("biomaRt")
# --------------------------------------------------
# 2. MAP GENE NAMES (safer merge)
# --------------------------------------------------
mart <- useMart("ensembl", dataset = "hsapiens_gene_ensembl")
gene_map <- getBM(
attributes = c("ensembl_gene_id", "hgnc_symbol"),
filters = "ensembl_gene_id",
values = res_clean$ensembl,
mart = mart
)
BiocManager::install("AnnotationDbi")
# Annotate Ensembl IDs to gene symbols using local annotation database
library(AnnotationDbi)
citation("AnnotationDbi")
gene_symbols <- mapIds(org.Hs.eg.db,
keys = rownames(res_clean),
column = "SYMBOL",
keytype = "ENSEMBL",
multiVals = "first")
# Add gene symbols to results table
res_clean$symbol <- gene_symbols
# Use shrinkage-adjusted log2 fold changes for visualization
res_clean$log2FC <- resLFC$log2FoldChange[
match(rownames(res_clean), rownames(resLFC))
]
# Define thresholds for significance
padj_cutoff <- 0.05
lfc_cutoff <- 1
res_clean$significant <- res_clean$padj < padj_cutoff &
abs(res_clean$log2FC) > lfc_cutoff
# Select immune-response genes for labeling
genes_of_interest <- c("IFIT1", "IFIT3", "ISG15", "MX1")
label_data <- res_clean[res_clean$symbol %in% genes_of_interest, ]
ggplot(res_clean, aes(x = log2FC, y = -log10(padj))) +
geom_point(aes(color = significant), alpha = 0.6, size = 1.5) +
scale_color_manual(values = c("grey", "red")) +
geom_vline(xintercept = c(-lfc_cutoff, lfc_cutoff), linetype = "dashed") +
geom_hline(yintercept = -log10(padj_cutoff), linetype = "dashed") +
geom_text(data = label_data,
aes(label = symbol),
size = 3,
vjust = -1) +
theme_minimal() +
labs(title = "Volcano Plot",
x = "Log2 Fold Change (shrunk)",
y = "-Log10 Adjusted P-value")
View(raw_counts)
View(resLFC)
# Sort by Log2FoldChange (highest to lowest)
res_sorted <- res[order(-res$log2FoldChange), ]
head(res_sorted, 10)
# Sort by Significance (most significant first)
res_sig_sorted <- res[order(res$padj), ]
head(res_sig_sorted, 10)
# 1. Take your significant results (already sorted by padj)
top50 <- head(res_sig_sorted, 50)
# 2. Add a new column called 'symbol' by looking up the rownames
top50$symbol <- mapIds(org.Hs.eg.db,
keys = rownames(top50),
column = "SYMBOL",
keytype = "ENSEMBL",
multiVals = "first")
# 3. View the result
View(as.data.frame(top50))
down_genes <- head(res_clean[order(res_clean$log2FoldChange), ], 5)
down_genes$hgnc_symbol
# 1. Get the 5 genes with the most negative Fold Change
down_genes <- head(res_clean[order(res_clean$log2FoldChange), ], 5)
# 2. Map the symbols (the "translation" step)
down_genes$symbol <- mapIds(org.Hs.eg.db,
keys = rownames(down_genes),
column = "SYMBOL",
keytype = "ENSEMBL",
multiVals = "first")
# 3. Check the results
as.data.frame(down_genes[, c("log2FoldChange", "padj", "symbol")])
# 3. Check the results
as.data.frame(down_genes[, c("log2FoldChange", "padj", "symbol")])
View(down_genes)
